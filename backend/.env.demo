# CLEO Backend — Demo Environment Configuration
# Copy to .env for demo day. Uses best-quality model and tuned thresholds.

PROJECT_NAME=CLEO
API_V1_STR=/api/v1
DEBUG=false

# OpenAI — best quality for demo
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Azure OpenAI (direct chat module)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=your-deployment-name

# Pinecone
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=cleo-demo
PINECONE_ENVIRONMENT=us-east-1

# BookStack
BOOKSTACK_BASE_URL=https://your-bookstack-instance.com
BOOKSTACK_TOKEN_ID=your-token-id
BOOKSTACK_TOKEN_SECRET=your-token-secret

# RAG Tuning — slightly more permissive for demo questions
MIN_SIMILARITY_SCORE=0.72
TOP_K_RESULTS=3

# Sync
SYNC_INTERVAL_MINUTES=15

# Security
ADMIN_API_KEY=demo-admin-key-change-me
ALLOWED_ORIGINS=http://localhost:3000,https://your-demo-frontend.com
RATE_LIMIT_PER_MINUTE=30
WEBHOOK_SECRET=your-webhook-secret
