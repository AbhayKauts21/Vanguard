# ============================================
# CLEO — Environment Configuration
# ============================================
# Copy this file to .env and fill in your keys.

# === Project ===
PROJECT_NAME="CLEO"
DEBUG=true
API_V1_STR="/api/v1"
SECRET_KEY="your-super-secret-key-for-development"

# === Embeddings ===
EMBEDDING_DIMENSIONS=3072

# === Azure OpenAI Foundry ===
# Use the resource endpoint only. The app appends /openai/v1/ internally.
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com"
AZURE_OPENAI_API_KEY="..."
AZURE_OPENAI_API_VERSION="2024-08-01-preview"
AZURE_OPENAI_CHAT_DEPLOYMENT="gpt-4o-mini"
AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-3-large"
AZURE_OPENAI_AUTH_MODE="api_key"
AZURE_OPENAI_TIMEOUT_SECONDS=30
AZURE_OPENAI_MAX_RETRIES=2

# === Pinecone ===
PINECONE_API_KEY="pcsk_..."
PINECONE_INDEX_NAME="cleo-docs"
PINECONE_CLOUD="aws"
PINECONE_REGION="us-east-1"
DOCUMENT_VECTOR_NAMESPACE="bookstack"

# === BookStack ===
BOOKSTACK_URL="https://your-bookstack-instance.com"
BOOKSTACK_TOKEN_ID="..."
BOOKSTACK_TOKEN_SECRET="..."
BOOKSTACK_SOURCE_KEY="bookstack_default"
BOOKSTACK_SOURCE_NAME="BookStack"

# === Azure Blob Storage (User Uploads) ===
# Prefer the connection string. If you use account URL mode,
# set AZURE_BLOB_ACCOUNT_URL, AZURE_BLOB_ACCOUNT_NAME, and AZURE_BLOB_ACCOUNT_KEY.
AZURE_BLOB_CONNECTION_STRING=""
AZURE_BLOB_ACCOUNT_URL="https://your-storage-account.blob.core.windows.net"
AZURE_BLOB_ACCOUNT_NAME="your-storage-account"
AZURE_BLOB_ACCOUNT_KEY=""
AZURE_BLOB_CONTAINER_NAME="cleo-user-documents"
AZURE_BLOB_SAS_EXPIRY_MINUTES=1440
DOCUMENT_UPLOAD_MAX_BYTES=20971520

# === Ingestion Pipeline ===
CHUNK_SIZE=800
CHUNK_OVERLAP=200
MIN_SIMILARITY_SCORE=0.78
SYNC_INTERVAL_MINUTES=5
TOP_K_RESULTS=5

# === Webhook ===
BOOKSTACK_WEBHOOK_SECRET="your_webhook_secret"

# === Security ===
ADMIN_API_KEY="change-me-in-production"
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
RATE_LIMIT_PER_MINUTE=30

# === Postgres / Auth ===
POSTGRES_HOST="127.0.0.1"
POSTGRES_PORT=5432
POSTGRES_DB="cleo_auth"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
JWT_SECRET_KEY="replace-with-a-long-random-secret"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14
AUTH_DEFAULT_ROLE="admin"
PASSWORD_RESET_CODE_EXPIRE_MINUTES=15

# === HeyGen (Avatar) ===
HEYGEN_API_KEY="..."

# === Azure Speech Services (Voice Pipeline TTS) ===
AZURE_SPEECH_KEY="your-azure-speech-key"
AZURE_SPEECH_REGION="eastus2"
AZURE_TTS_VOICE="en-US-Ava:DragonHDLatestNeural"
AZURE_TTS_OUTPUT_FORMAT="audio-24khz-160kbitrate-mono-mp3"

# === OpenTelemetry ===
# Set to 'true' only if you have an OTLP collector running at the endpoint below.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
OTEL_SERVICE_NAME="cleo-backend"
OTEL_CONSOLE_EXPORTER=false

