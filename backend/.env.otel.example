# OpenTelemetry Configuration (Backend)

# Enable/disable OpenTelemetry
OTEL_ENABLED=true

# Service identification
OTEL_SERVICE_NAME=cleo-backend
SERVICE_VERSION=1.0.0
ENVIRONMENT=development

# OTEL Collector endpoint (gRPC)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Console exporter (for debugging, set to true in development)
OTEL_CONSOLE_EXPORTER=false

# Logging configuration
LOG_LEVEL=INFO
LOG_FORMAT=json  # Use "pretty" for development, "json" for production
