ARG NODE_VERSION=22.22.0

# ---- Stage 1: Build ----
FROM node:${NODE_VERSION}-slim AS builder

WORKDIR /app

ENV NEXT_TELEMETRY_DISABLED=1

# Install dependencies first (better layer caching)
COPY package.json package-lock.json* ./
RUN npm install

# Copy source and build
COPY . .

# Build-time env vars must be available at build time for Next.js
# They get inlined into the JS bundle during `next build`.
# Declare all NEXT_PUBLIC_* variables as ARG and ENV
ARG NEXT_PUBLIC_APP_NAME=CLEO
ARG NEXT_PUBLIC_DEFAULT_LOCALE=en
ARG NEXT_PUBLIC_SUPPORTED_LOCALES=en,es
ARG NEXT_PUBLIC_API_BASE_URL=https://cleoapi.andinolabs.tech
ARG NEXT_PUBLIC_ENABLE_AVATAR=false
ARG NEXT_PUBLIC_ENABLE_AMBIENT_EFFECTS=true
ARG NEXT_PUBLIC_ENABLE_STREAMING=true
ARG NEXT_PUBLIC_HEYGEN_AVATAR_ID=""
ARG NEXT_PUBLIC_HEYGEN_VOICE_ID=""
ARG NEXT_PUBLIC_HEYGEN_VOICE_ID_ES=""
ARG NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
ARG NEXT_PUBLIC_OTEL_ENABLED=true
ARG NEXT_PUBLIC_APP_VERSION=1.0.0
ARG NEXT_PUBLIC_ADMIN_API_KEY=""

# Set as environment variables for Next.js build
ENV NEXT_PUBLIC_APP_NAME=$NEXT_PUBLIC_APP_NAME
ENV NEXT_PUBLIC_DEFAULT_LOCALE=$NEXT_PUBLIC_DEFAULT_LOCALE
ENV NEXT_PUBLIC_SUPPORTED_LOCALES=$NEXT_PUBLIC_SUPPORTED_LOCALES
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_ENABLE_AVATAR=$NEXT_PUBLIC_ENABLE_AVATAR
ENV NEXT_PUBLIC_ENABLE_AMBIENT_EFFECTS=$NEXT_PUBLIC_ENABLE_AMBIENT_EFFECTS
ENV NEXT_PUBLIC_ENABLE_STREAMING=$NEXT_PUBLIC_ENABLE_STREAMING
ENV NEXT_PUBLIC_HEYGEN_AVATAR_ID=$NEXT_PUBLIC_HEYGEN_AVATAR_ID
ENV NEXT_PUBLIC_HEYGEN_VOICE_ID=$NEXT_PUBLIC_HEYGEN_VOICE_ID
ENV NEXT_PUBLIC_HEYGEN_VOICE_ID_ES=$NEXT_PUBLIC_HEYGEN_VOICE_ID_ES
ENV NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT=$NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT
ENV NEXT_PUBLIC_OTEL_ENABLED=$NEXT_PUBLIC_OTEL_ENABLED
ENV NEXT_PUBLIC_APP_VERSION=$NEXT_PUBLIC_APP_VERSION
ENV NEXT_PUBLIC_ADMIN_API_KEY=$NEXT_PUBLIC_ADMIN_API_KEY

RUN npm run build

# ---- Stage 2: Production Runner ----
FROM node:${NODE_VERSION}-slim AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Copy standalone output + static assets + public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000

CMD ["node", "server.js"]
