# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which may contain sensitive data
*.tfvars
*.tfvars.json

# Backend configuration (may contain sensitive account names)
backend-config.hcl

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore Azure credentials for local development
.env.azure
*.env.azure

# Ignore Mac files
.DS_Store

# Ignore lock file (optional - remove if you want to version lock file)
# .terraform.lock.hcl
