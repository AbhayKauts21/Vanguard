# Terraform Variables Configuration
# Copy this file to terraform.tfvars and fill in your values

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Required: Azure Subscription ID
subscription_id = "YOUR_SUBSCRIPTION_ID_HERE"

# Required: Azure Tenant ID for ANDINO GLOBAL TECH PRIVATE LIMITED
tenant_id = "YOUR_TENANT_ID_HERE"

# =============================================================================
# OPTIONAL: BASIC CONFIGURATION
# =============================================================================

# resource_group_name     = "vanguard"
# location                = "eastus"
# project_name            = "vanguard"
# environment             = "demo"
# vm_size                 = "Standard_B4ms"
# admin_username          = "azureadmin"
# ssh_public_key_path     = "~/.ssh/id_rsa.pub"

# =============================================================================
# OPTIONAL: NETWORK CONFIGURATION
# =============================================================================

# vnet_address_space      = ["10.0.0.0/16"]
# subnet_address_prefix   = "10.0.1.0/24"

# =============================================================================
# OPTIONAL: SECURITY - CIDR RESTRICTIONS
# =============================================================================
# IMPORTANT: Restrict these for production! Default allows all (0.0.0.0/0)

# SSH access (highly recommended to restrict!)
# allowed_ssh_cidrs       = ["YOUR_IP/32"]  # Replace with your IP

# HTTP/HTTPS access
# allowed_http_cidrs      = ["0.0.0.0/0"]
# allowed_https_cidrs     = ["0.0.0.0/0"]

# Grafana dashboard access (recommended to restrict!)
# allowed_grafana_cidrs   = ["YOUR_IP/32"]  # Replace with your IP

# =============================================================================
# OPTIONAL: POSTGRESQL REMOTE ACCESS
# =============================================================================
# IMPORTANT: Remote PostgreSQL access is DISABLED by default (recommended)
# Only enable if you need to connect from outside the VM

# postgresql_remote_access = false
# postgresql_allowed_cidr  = "10.0.0.0/16"  # VNet CIDR if enabled

# =============================================================================
# OPTIONAL: CUSTOM TAGS
# =============================================================================

# tags = {
#   project     = "vanguard"
#   environment = "demo"
#   department  = "engineering"
#   cost_center = "engineering-ops"
# }
